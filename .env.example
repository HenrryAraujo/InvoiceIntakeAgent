# Copy this file to .env and provide your key. NEVER commit .env (it is gitignored).
OPENAI_API_KEY=replace-with-your-openai-api-key

# --- Optional overrides (defaults shown; safe to leave commented) ---
# INPUT_DIR=data
# OUTPUT_DIR=output

# Model selection — ONLY "gpt-5-mini" or "gpt-5-nano" are accepted.
# Any other value aborts startup via the model allow-list guard.
# EXTRACTOR_MODEL=gpt-5-mini
# AGENT_MODEL=gpt-5-mini
# JUDGE_MODEL=gpt-5-nano

# --- Vision / cost controls ---
# RENDER_DPI=150
# MAX_PAGES=4
# MAX_TURNS=4

# --- Observability ---
# ENABLE_TRACING=true
# ENABLE_JUDGE=false
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db
# MLFLOW_EXPERIMENT=invoice-intake-agent
