# Copy this file to .env and provide your key. NEVER commit .env (it is gitignored).
OPENAI_API_KEY=replace-with-your-openai-api-key

# --- Optional overrides (defaults shown; safe to leave commented) ---
# INPUT_DIR=input_data
# OUTPUT_DIR=output_data

# --- Logging (LOG_LEVEL: DEBUG=full local dev, INFO=minimal, WARNING=quiet) ---
# LOG_FORMAT: plain (human-readable) or json (structured production telemetry).
# LOG_LEVEL=DEBUG
# LOG_FORMAT=plain

# --- HITL approval: persona-based Delegation of Authority ---
# ACTIVE_PERSONA picks the default approver (rep|supervisor) when --persona is omitted.
# ACTIVE_PERSONA=rep
# APPROVAL_CURRENCY=CAD
# ESCALATION_CONTACT=Finance Manager
# HOLD_ON_DUPLICATE=false
# PERSONA_REP_TITLE=Customer Service Representative
# PERSONA_REP_LIMIT=10000
# PERSONA_SUPERVISOR_TITLE=Customer Service Supervisor
# PERSONA_SUPERVISOR_LIMIT=150000

# Model selection — ONLY "gpt-5-mini" or "gpt-5-nano" are accepted.
# Any other value aborts startup via the model allow-list guard.
# EXTRACTOR_MODEL=gpt-5-mini
# AGENT_MODEL=gpt-5-mini
# JUDGE_MODEL=gpt-5-nano

# --- Vision / cost controls ---
# RENDER_DPI=150
# MAX_PAGES=4
# MAX_TURNS=4

# --- Observability ---
# ENABLE_TRACING=true
# ENABLE_JUDGE=false
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db
# MLFLOW_EXPERIMENT=invoice-intake-agent
